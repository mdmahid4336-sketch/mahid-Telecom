{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "isActive": { "type": "boolean" },
        "accountType": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["id", "name", "phone", "balance", "isActive"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Recharge", "Bill Pay", "Transfer", "Add Balance"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Success", "Pending", "Failed"] },
        "description": { "type": "string" }
      },
      "required": ["id", "userId", "type", "amount", "date", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application global settings",
      "type": "object",
      "properties": {
        "apkDownloadUrl": { "type": "string" },
        "whatsappLink": { "type": "string" },
        "helplineNumber": { "type": "string" },
        "appLogo": { "type": "string" },
        "appName": { "type": "string" }
      }
    },
    "Package": {
      "title": "Package",
      "description": "Mobile drive or regular data/minute packages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "operator": { "type": "string" },
        "title": { "type": "string" },
        "duration": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "finalPrice": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "operator", "title", "duration", "price", "finalPrice"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction history"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global application settings"
    },
    "/packages/{packageId}": {
      "schema": "Package",
      "description": "Mobile packages and drives"
    },
    "/notices/current": {
      "schema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "isActive": { "type": "boolean" },
          "updatedAt": { "type": "string" }
        }
      },
      "description": "Current system notice"
    }
  }
}
